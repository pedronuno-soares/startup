{
  "name": "dems-orchestrator",
  "version": "1.0.0",
  "description": "API Gateway para Sistema de Cadeia de Custódia Distribuída",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "dev:local": "cross-env LOCAL_DEV=true PORT=8888 ts-node-dev --respawn --transpile-only src/server.ts"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "form-data": "^4.0.5",
    "googleapis": "^171.4.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^9.2.4",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^4.17.18",
    "@types/jsonwebtoken": "^9.0.3",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.8.2",
    "@types/pg": "^8.10.2",
    "cross-env": "^7.0.3",
    "mongodb-memory-server": "^10.1.4",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.2.2"
  }
}